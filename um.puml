
---

## 2) Conteúdo do arquivo `.puml`

```puml
@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam actorStyle awesome

actor "Usuário" as Usuario

rectangle "Aplicação de Consulta de\nRegistros Binários" {

  usecase "Carregar arquivo\nmyfile.dat" as UC_Carregar
  usecase "Consultar registros\npor tipo" as UC_ConsultarTipo
  usecase "Mostrar todos os\nregistros" as UC_MostrarTodos
  usecase "Exibir enunciado\ndo problema" as UC_Enunciado
  usecase "Exibir detalhes de\nimplementação" as UC_Detalhes
  usecase "Sair do sistema" as UC_Sair

  usecase "Ler opção\ndo menu" as UC_Menu
  usecase "Ler tipo informado\npelo usuário" as UC_LerTipo
}

rectangle "Controller" {
  usecase "Interpretar opção\ne acionar fluxo" as CTRL_Fluxo
}

rectangle "Service" {
  usecase "Coordenar carga\ndos dados" as SRV_Carga
  usecase "Projetar registros\npor tipo" as SRV_Projecao
  usecase "Listar todos os\nregistros" as SRV_Listagem
  usecase "Encerrar aplicação e\nliberar memória" as SRV_Encerrar
}

rectangle "Repository" {
  usecase "Abrir arquivo em\nmodo binário" as REP_Abrir
  usecase "Ler registros no formato\nType Length Content" as REP_Ler
}

rectangle "Lista Encadeada" {
  usecase "Inserir nodo no fim" as LISTA_Inserir
  usecase "Percorrer estrutura\nem memória" as LISTA_Percorrer
  usecase "Liberar nodos e buffers" as LISTA_Liberar
}

Usuario --> UC_Carregar
Usuario --> UC_ConsultarTipo
Usuario --> UC_MostrarTodos
Usuario --> UC_Enunciado
Usuario --> UC_Detalhes
Usuario --> UC_Sair

UC_Carregar .> UC_Menu : <<include>>
UC_ConsultarTipo .> UC_Menu : <<include>>
UC_MostrarTodos .> UC_Menu : <<include>>
UC_Enunciado .> UC_Menu : <<include>>
UC_Detalhes .> UC_Menu : <<include>>
UC_Sair .> UC_Menu : <<include>>

UC_ConsultarTipo .> UC_LerTipo : <<include>>

UC_Carregar .> CTRL_Fluxo : <<include>>
UC_ConsultarTipo .> CTRL_Fluxo : <<include>>
UC_MostrarTodos .> CTRL_Fluxo : <<include>>
UC_Sair .> CTRL_Fluxo : <<include>>

CTRL_Fluxo .> SRV_Carga : <<include>>
CTRL_Fluxo .> SRV_Projecao : <<include>>
CTRL_Fluxo .> SRV_Listagem : <<include>>
CTRL_Fluxo .> SRV_Encerrar : <<include>>

SRV_Carga .> REP_Abrir : <<include>>
SRV_Carga .> REP_Ler : <<include>>
SRV_Carga .> LISTA_Inserir : <<include>>

SRV_Projecao .> LISTA_Percorrer : <<include>>
SRV_Listagem .> LISTA_Percorrer : <<include>>
SRV_Encerrar .> LISTA_Liberar : <<include>>

note right of UC_Enunciado
  Enunciado apresentado pela aplicação:
  - abrir myfile.dat em leitura binária
  - carregar os registros em memória
  - permitir projeção por tipo
  - tipos C, I, F e S
end note

note right of UC_Detalhes
  Detalhes técnicos declarados:
  - PGPPCA-UFFS 2026.1
  - MCET042
  - Discente Valdemar Lorenzon Junior
  - ANSI C89
  - arquitetura em camadas
  - lista simplesmente encadeada
  - gerenciamento de memória
end note

note bottom of SRV_Carga
  O service funciona como ponto
  de amarração da solução,
  coordenando repository e lista
  a partir da intenção recebida
  pelo controller.
end note

@enduml